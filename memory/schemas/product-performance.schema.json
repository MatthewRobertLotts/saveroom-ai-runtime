{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Product Performance Memory",
  "description": "Observations about how specific products or product types have performed. Each record is a dated observation, not a permanent truth. Confidence levels must be set honestly.",
  "type": "object",
  "required": ["records"],
  "properties": {
    "records": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "product_name", "date_observed", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "product_name": { "type": "string" },
          "set": { "type": "string" },
          "language": { "type": "string", "enum": ["English", "Japanese", "Korean", "Simplified Chinese", "Other"] },
          "supplier": { "type": "string" },
          "source_type": { "type": "string", "enum": ["shop", "wholesaler", "marketplace", "private_seller", "unknown"] },
          "buy_price_gbp": { "type": "number" },
          "pack_count": { "type": "integer" },
          "unit_count": { "type": "integer" },
          "cost_per_pack_gbp": { "type": "number" },
          "cost_per_unit_gbp": { "type": "number" },
          "typical_sale_price_gbp": { "type": "number" },
          "sell_through_notes": { "type": "string" },
          "audience_response": { "type": "string" },
          "margin_notes": { "type": "string" },
          "dead_stock_risk": { "type": "string", "enum": ["low", "medium", "high", "unknown"] },
          "date_observed": { "type": "string", "format": "date" },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
          "source": { "type": "string", "description": "Where this observation came from: stream date, supplier data, etc." }
        }
      }
    }
  }
}
