{
  "workflows": [
    {
      "name": "marketing-stream",
      "description": "Create a marketing stream asset bundle.",
      "required_inputs": ["stream_theme", "featured_languages", "featured_products", "tone"],
      "optional_inputs": ["audience", "cta"],
      "execution_steps": [
        { "agent": "Gary", "mode": "delegation", "task": "Break down the marketing stream into specialist tasks." },
        { "agent": "Todd", "mode": "execution", "task": "Draft stream title, Instagram caption, Discord announcement, and bundle ideas." },
        { "agent": "Tracey", "mode": "execution", "task": "Refine the marketing assets for warmth, trust, and readability." },
        { "agent": "Gary", "mode": "finalisation", "task": "Synthesize the final marketing stream bundle." }
      ],
      "output_artifacts": [
        "outputs/stream/title.txt",
        "outputs/stream/instagram-caption.txt",
        "outputs/stream/discord-announcement.txt",
        "outputs/stream/bundle-ideas.txt"
      ]
    },
    {
      "name": "finance-analysis",
      "description": "Analyze finance data from a CSV input.",
      "required_inputs": ["csv_path", "analysis_focus"],
      "optional_inputs": ["timeframe", "inventory_context"],
      "execution_steps": [
        { "agent": "Giovanni", "mode": "execution", "task": "Inspect the finance data and produce profitability diagnostics." },
        { "agent": "Giovanni", "mode": "finalisation", "task": "Synthesize the finance findings into a final report." }
      ],
      "output_artifacts": [
        "reports/finance-analysis/run-.../report.md",
        "reports/finance-analysis/run-.../fee-observations.txt",
        "reports/finance-analysis/run-.../margin-warnings.txt",
        "reports/finance-analysis/run-.../high-performing-stock-observations.txt",
        "reports/finance-analysis/run-.../restock-recommendations.txt",
        "reports/finance-analysis/run-.../profitability-summary.txt"
      ]
    },
    {
      "name": "shopify-listing",
      "description": "Prepare a Shopify listing package.",
      "required_inputs": ["product_name", "product_type", "language", "condition", "price_target"],
      "optional_inputs": ["tone", "seo_focus"],
      "execution_steps": [
        { "agent": "Todd", "mode": "execution", "task": "Draft listing title, description, tags, shipping notes, and pricing guidance." },
        { "agent": "Tracey", "mode": "execution", "task": "Refine listing copy for clarity and trust." },
        { "agent": "Gary", "mode": "finalisation", "task": "Finalize the Shopify listing package." }
      ],
      "output_artifacts": [
        "outputs/listings/title.txt",
        "outputs/listings/description.md",
        "outputs/listings/tags.txt",
        "outputs/listings/shipping-notes.txt",
        "outputs/listings/pricing-guidance.txt"
      ]
    },
    {
      "name": "supplier-analysis",
      "description": "Analyze supplier and sourcing data for research and inventory intelligence.",
      "required_inputs": ["source_path", "analysis_focus"],
      "optional_inputs": ["supplier_name", "category"],
      "execution_steps": [
        { "agent": "Professor Oak", "mode": "execution", "task": "Interpret supplier and sourcing evidence." },
        { "agent": "Professor Oak", "mode": "finalisation", "task": "Synthesize supplier analysis into a practical report." }
      ],
      "output_artifacts": [
        "insights/research/run-.../supplier-summary.txt",
        "insights/research/run-.../sourcing-observations.txt"
      ]
    },
    {
      "name": "product-trend-analysis",
      "description": "Analyze product and category trends.",
      "required_inputs": ["source_path", "analysis_focus"],
      "optional_inputs": ["category", "region"],
      "execution_steps": [
        { "agent": "Professor Oak", "mode": "execution", "task": "Assess product and category trend context." },
        { "agent": "Professor Oak", "mode": "finalisation", "task": "Synthesize product trend observations." }
      ],
      "output_artifacts": [
        "insights/research/run-.../trend-summary.txt",
        "insights/research/run-.../category-observations.txt"
      ]
    },
    {
      "name": "release-impact-analysis",
      "description": "Assess release timing and market impact.",
      "required_inputs": ["source_path", "analysis_focus"],
      "optional_inputs": ["set_name", "release_window"],
      "execution_steps": [
        { "agent": "Professor Oak", "mode": "execution", "task": "Interpret release timing and product impact." },
        { "agent": "Professor Oak", "mode": "finalisation", "task": "Synthesize release impact findings." }
      ],
      "output_artifacts": [
        "insights/research/run-.../release-impact.txt"
      ]
    },
    {
      "name": "inventory-opportunity-analysis",
      "description": "Identify inventory opportunities and sourcing gaps.",
      "required_inputs": ["source_path", "analysis_focus"],
      "optional_inputs": ["supplier_name", "inventory_context"],
      "execution_steps": [
        { "agent": "Professor Oak", "mode": "execution", "task": "Review inventory opportunity signals and gaps." },
        { "agent": "Professor Oak", "mode": "finalisation", "task": "Synthesize inventory opportunity recommendations." }
      ],
      "output_artifacts": [
        "insights/research/run-.../inventory-opportunities.txt",
        "insights/research/run-.../sourcing-gaps.txt"
      ]
    }
  ]
}
